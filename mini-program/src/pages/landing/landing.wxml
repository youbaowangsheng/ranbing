<!-- pages/landing/landing.wxml -->
<view class="container">
  <!-- 顶部 Hero -->
  <view class="hero-section">
    <view class="hero-bg">
      <view class="hero-overlay"></view>
    </view>
    <view class="hero-content">
      <image class="logo-icon" src="/assets/logo.png" mode="aspectFit" />
      <view class="logo-text">燃冰</view>
      <view class="logo-sub">AI 驱动的新一代商务社交平台</view>

      <!-- 快速数据 -->
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-num">10,000+</view>
          <view class="stat-label">商务用户</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num">500+</view>
          <view class="stat-label">精选活动</view>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <view class="stat-num">50+</view>
          <view class="stat-label">行业社群</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="quick-entry-section">
    <view class="section-title">快速看看</view>
    <view class="quick-cards">
      <view class="quick-card" bindtap="toActivities">
        <view class="quick-icon">📅</view>
        <view class="quick-info">
          <view class="quick-title">热门活动</view>
          <view class="quick-desc">沙龙、路演、培训、社交聚会</view>
        </view>
        <view class="quick-arrow">›</view>
      </view>
      <view class="quick-card" bindtap="toCommunities">
        <view class="quick-icon">👥</view>
        <view class="quick-info">
          <view class="quick-title">行业社群</view>
          <view class="quick-desc">加入感兴趣的社群，拓展人脉</view>
        </view>
        <view class="quick-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 三大核心价值 -->
  <view class="features-section">
    <view class="section-title">平台核心价值</view>
    <view class="feature-card">
      <view class="feature-icon">🔥</view>
      <view class="feature-content">
        <view class="feature-title">AI 精准匹配</view>
        <view class="feature-desc">基于 DeepSeek 大模型，智能分析人脉资源与需求，精准推荐匹配机会。系统学习你的行业背景、合作偏好，自动发现高价值人脉。</view>
      </view>
    </view>
    <view class="feature-card">
      <view class="feature-icon">🤝</view>
      <view class="feature-content">
        <view class="feature-title">高效商务社群</view>
        <view class="feature-desc">加入行业社群，拓展人脉资源，获取最新商机动态，与同行深度交流。覆盖互联网、金融、制造等多个行业。</view>
      </view>
    </view>
    <view class="feature-card">
      <view class="feature-icon">📇</view>
      <view class="feature-content">
        <view class="feature-title">AI 名片分享</view>
        <view class="feature-desc">一键生成分享名片，二维码扫码即加好友，让商务对接更高效。告别纸质名片，人脉永不丢失。</view>
      </view>
    </view>
  </view>

  <!-- 如何使用 -->
  <view class="howitworks-section">
    <view class="section-title">如何使用</view>
    <view class="steps-row">
      <view class="step-item">
        <view class="step-num">1</view>
        <view class="step-text">注册账号</view>
      </view>
      <view class="step-line"></view>
      <view class="step-item">
        <view class="step-num">2</view>
        <view class="step-text">完善资料</view>
      </view>
      <view class="step-line"></view>
      <view class="step-item">
        <view class="step-num">3</view>
        <view class="step-text">浏览社群</view>
      </view>
      <view class="step-line"></view>
      <view class="step-item">
        <view class="step-num">4</view>
        <view class="step-text">参加活动</view>
      </view>
    </view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-section">
    <button class="btn-register" bindtap="toRegister">立即加入</button>
    <view class="login-hint">
      已有账号？
      <text bindtap="toLogin">直接登录</text>
    </view>
  </view>
</view>
